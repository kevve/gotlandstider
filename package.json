{
  "name": "gotlandstider",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "dev": "tailwindcss -i ./src/input.css -o ./output.css --watch",
    "build": "tailwindcss -i ./src/input.css -o ./output.css --minify",
    "build:content": "node ./scripts/build-content.mjs",
    "build:homepage-shell": "node ./scripts/build-homepage-shell.mjs",
    "build:pages": "node ./scripts/build-pages.mjs",
    "build:seo": "node ./scripts/build-seo.mjs",
    "build:site": "npm run build:content && npm run build:pages && npm run build:homepage-shell && npm run build:seo && npm run build",
    "publisher:prepare": "node \"${GOTLANDSTIDER_AI_ROOT:-../gotlandstider-ai}/scripts/prepare-content-publisher-worktree.mjs\"",
    "publisher:preflight": "node \"${GOTLANDSTIDER_AI_ROOT:-../gotlandstider-ai}/scripts/content-publisher-preflight.mjs\"",
    "publisher:open-pr": "node \"${GOTLANDSTIDER_AI_ROOT:-../gotlandstider-ai}/scripts/content-publisher-open-pr.mjs\"",
    "validate:content": "node ./scripts/validate-content.mjs",
    "test:content": "node --test ./tests/content-validation.test.mjs ./tests/build-content.test.mjs",
    "test:pages": "node --test ./tests/build-pages.test.mjs ./tests/homepage-nav.test.mjs ./tests/build-homepage-shell.test.mjs",
    "test:publisher": "npm --prefix \"${GOTLANDSTIDER_AI_ROOT:-../gotlandstider-ai}\" run test:publisher",
    "test:seo": "node --test ./tests/build-seo.test.mjs",
    "check:site": "npm run validate:content && npm run test:content && npm run test:pages && npm run test:publisher && npm run test:seo && npm run build:site"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.1",
    "yaml": "^2.8.2"
  }
}
